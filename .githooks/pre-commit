#!/bin/bash
set -euo pipefail

# This is a githook dispatcher. It runs all executable scripts in 
# .githooks/$(basename "$0").d/

# Find the root of the git repository
GIT_ROOT=$(git rev-parse --show-toplevel)

HOOK_NAME=$(basename "$0")
HOOKS_DIR="$GIT_ROOT/.githooks/${HOOK_NAME}.d"

EXIT_CODE=0

if [ -d "$HOOKS_DIR" ]; then
    # We use a temp file to track if any hook fails across the subshell
    FAILURE_FILE=$(mktemp)
    echo "0" > "$FAILURE_FILE"

    find "$HOOKS_DIR" -maxdepth 1 -type f -executable | while read -r hook; do
        if ! "$hook"; then
            echo "1" > "$FAILURE_FILE"
        fi
    done

    if [ "$(cat "$FAILURE_FILE")" -eq 1 ]; then
        EXIT_CODE=1
    fi
    rm -f "$FAILURE_FILE"
fi

exit $EXIT_CODE
